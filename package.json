{
  "name": "makeplace",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @makeplace/api\" \"npm run dev -w @makeplace/web\"",
    "build": "npm run build -w @makeplace/api && npm run build -w @makeplace/web",
    "db:migrate": "npm run db:migrate -w @makeplace/api",
    "db:seed": "npm run db:seed -w @makeplace/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
