# Database
DATABASE_URL=postgresql://makeplace:makeplace@localhost:5432/makeplace

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Storage: "local" (default when R2 not set) or "r2"
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads

# Cloudflare R2 (S3-compatible) — only needed when STORAGE_MODE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=makeplace-uploads
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Claude API
ANTHROPIC_API_KEY=

# n8n
N8N_WEBHOOK_SECRET=change-me

# App URLs
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ports
API_PORT=3001
WEB_PORT=3000
