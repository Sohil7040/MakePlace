    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "@google/genai": "latest",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.2",
    "resend": "^6.14.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.5",
    "prisma": "^6.4.1",
